# Copy this file to `.env` and fill in your local MySQL credentials.
# The app will load it automatically via python-dotenv.
# Never commit the real `.env` file (it is gitignored).

STUDY_TRACKER_DB_HOST=127.0.0.1
STUDY_TRACKER_DB_PORT=3306
STUDY_TRACKER_DB_USER=root
STUDY_TRACKER_DB_PASSWORD=your_mysql_password_here
STUDY_TRACKER_DB_NAME=study_tracker
